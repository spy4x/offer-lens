# OfferLens
# Copy to .env and fill in values

# Demo API key for the AI model (DeepSeek or OpenAI-compatible)
# SERVER-SIDE ONLY — never exposed to clients
DEMO_OPENAI_API_KEY=REPLACE_WITH_DEEPSEEK_API_KEY

# OpenAI API base URL (default: DeepSeek)
OPENAI_API_BASE=https://api.deepseek.com

# LLM model to use
LLM_MODEL=deepseek-chat

# Server
PORT=8000
WEB_PORT=3000

# Database (optional — uses in-memory store if not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=offerlens
DB_USER=offerlens
DB_PASS=offerlens

# Encryption key for BYOK (32 hex chars = 16 bytes AES-128 or 64 hex chars = 32 bytes AES-256)
# Generate: deno eval "console.log([...crypto.getRandomValues(new Uint8Array(32))].map(b=>b.toString(16).padStart(2,'0')).join(''))"
ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS

# Batch processing
BATCH_CONCURRENCY=5
